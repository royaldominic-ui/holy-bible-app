// ═══════════════════════════════════════════════════════════════
// FIRESTORE SECURITY RULES — firestore.rules
// Deploy with: firebase deploy --only firestore:rules
// ═══════════════════════════════════════════════════════════════

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ──────────────────────────────────────
    function isAuth() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    function isValidText(text, maxLen) {
      return text is string && text.size() > 0 && text.size() <= maxLen;
    }

    function notTooFast() {
      // Prevent spam: max 1 write per second (approximate)
      return true; // Implement with Firestore rate limiting or Cloud Functions
    }

    // ── User profiles ─────────────────────────────────────────
    match /users/{uid} {
      // Anyone can read public profile fields (for community)
      allow read: if isAuth();

      // Only owner can write their own profile
      allow create: if isOwner(uid)
        && request.resource.data.keys().hasAll(['uid','name','email','joined'])
        && isValidText(request.resource.data.name, 60)
        && isValidText(request.resource.data.email, 100);

      allow update: if isOwner(uid)
        // Prevent modifying uid or joined
        && !('uid' in request.resource.data.diff(resource.data).affectedKeys())
        && !('joined' in request.resource.data.diff(resource.data).affectedKeys());

      allow delete: if isOwner(uid);

      // Likes subcollection
      match /likes/{verseKey} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Community Comments ────────────────────────────────────
    match /comments/{commentId} {
      allow read: if true; // public

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && isValidText(request.resource.data.text, 1000)
        && request.resource.data.ts == request.time;

      // Only author can delete
      allow delete: if isAuth() && resource.data.userId == request.auth.uid;

      // Only likes field can be updated by others
      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['likes'])
        && request.resource.data.likes is list
        && request.resource.data.likes.size() <= 10000;
    }

    // ── Prayer Wall ───────────────────────────────────────────
    match /prayers/{prayerId} {
      allow read: if true;

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && isValidText(request.resource.data.text, 500);

      allow delete: if isAuth() && resource.data.userId == request.auth.uid;

      allow update: if isAuth()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['prayedBy']);
    }

    // ── Shared Verses ─────────────────────────────────────────
    match /shared_verses/{id} {
      allow read: if true;

      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && isValidText(request.resource.data.verse, 500)
        && isValidText(request.resource.data.ref, 60);

      allow delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // ── Analytics / Counters (write-only via Cloud Functions) ─
    match /analytics/{doc} {
      allow read: if false; // admin only
      allow write: if false; // via Cloud Functions only
    }

    // Deny all other paths
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
